{
  "name": "desk-api-config-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Windows desktop tool for managing LLM API configuration safely.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.0.0",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "vitest": "4.1.9",
    "wait-on": "9.0.10"
  }
}
